# Supabase — custom short links & logo storage (optional)
# Without this, the clock works fully via URL hash encoding.
#
# 1. Create a project at https://supabase.com
# 2. Copy values from Project Settings > API

VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── SQL: run in the Supabase SQL editor ──────────────────────────────────────
#
# CREATE TABLE public.links (
#   slug TEXT PRIMARY KEY CHECK (slug ~ '^[a-z0-9][a-z0-9-]{1,48}[a-z0-9]$'),
#   config JSONB NOT NULL,
#   user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,
#   created_at TIMESTAMPTZ DEFAULT NOW() NOT NULL
# );
# ALTER TABLE public.links ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "read"   ON public.links FOR SELECT USING (true);
# CREATE POLICY "insert" ON public.links FOR INSERT WITH CHECK (true);
# CREATE POLICY "update" ON public.links FOR UPDATE
#   USING (auth.uid() IS NOT NULL AND auth.uid() = user_id);
#
# ── Storage: logo uploads ─────────────────────────────────────────────────────
#
# Storage > New bucket:
#   Name: logos
#   Public bucket: ON
#
# Storage > Policies > logos bucket:
#   SELECT policy: true   (public read)
#   INSERT policy: true   (anyone can upload)
#
# ── Short URL format ──────────────────────────────────────────────────────────
#
# https://tableclock.io/my-clock
# Slug rules: lowercase letters, numbers, hyphens; 3–50 chars
# Duplicate slugs are rejected. Anonymous slugs cannot be updated later.
#
# ── Auth (optional) ───────────────────────────────────────────────────────────
#
# Authentication > Providers > Email > disable "Confirm email"
# so users are logged in immediately after signup.
